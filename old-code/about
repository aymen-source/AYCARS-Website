<script>
  const cards = document.querySelectorAll('.pillar,.founder-card,.fd-card,.member-type');
  const obs = new IntersectionObserver((entries) => { entries.forEach((e,i) => { if(e.isIntersecting){ setTimeout(()=>{ e.target.style.opacity='1'; e.target.style.transform='translateY(0)'; }, i*100); obs.unobserve(e.target); } }); }, {threshold:0.1});
  cards.forEach(el => { el.style.opacity='0'; el.style.transform='translateY(24px)'; el.style.transition='opacity 0.65s ease, transform 0.65s ease'; obs.observe(el); });
</script>
