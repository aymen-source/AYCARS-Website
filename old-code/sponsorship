  .nav-cta { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dark); background: var(--accent); padding: 0.5rem 1.4rem; text-decoration: none; transition: opacity 0.2s; font-weight: 600; }
  .nav-cta:hover { opacity: 0.85; }
  .btn-primary { font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; background: var(--accent); color: var(--dark); padding: 0.9rem 2.2rem; text-decoration: none; display: inline-block; transition: opacity 0.2s; font-weight: 600; }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost { font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; border: 0.5px solid rgba(137,207,240,0.5); color: var(--accent); padding: 0.9rem 2.2rem; text-decoration: none; display: inline-block; transition: background 0.2s; }
  .btn-ghost:hover { background: rgba(137,207,240,0.1); }
  .section-tag { font-family: 'Barlow Condensed', sans-serif; font-size: 0.68rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; display: flex; align-items: center; gap: 1rem; }
  .section-tag::before { content: ''; width: 30px; height: 0.5px; background: var(--accent); display: block; }
  .section-title { font-family: 'Bebas Neue', cursive; font-size: clamp(2.5rem, 4vw, 4rem); letter-spacing: 0.04em; line-height: 1; margin-bottom: 1.5rem; }
  .accent-divider { width: 40px; height: 0.5px; background: var(--accent); margin: 1.5rem 0; }

  /* PAGE HERO */
  .page-hero { height: 75vh; min-height: 520px; position: relative; display: flex; align-items: flex-end; overflow: hidden; padding-top: 70px; }
  .page-hero-bg { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,9,7,0.1) 0%, rgba(10,9,7,0.92) 100%), url('https://images.squarespace-cdn.com/content/v1/66c2f5aa67e20d6721774f6f/1724052910930-T3UI5DVGEP7QKJ0RC711/DSC07315+2.JPEG') center center / cover no-repeat; }
  .page-hero-content { position: relative; z-index: 2; padding: 0 4rem 5rem; max-width: 900px; }
  .breadcrumb { font-family: 'Barlow Condensed', sans-serif; font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--off-white); margin-bottom: 1rem; }
  .breadcrumb a { color: var(--accent); text-decoration: none; }
  .breadcrumb span { margin: 0 0.5rem; opacity: 0.4; }
  .page-title { font-family: 'Bebas Neue', cursive; font-size: clamp(3.5rem, 9vw, 8rem); line-height: 0.9; letter-spacing: 0.04em; }
  .page-sub { font-size: 1.1rem; color: var(--off-white); margin-top: 1.2rem; max-width: 580px; line-height: 1.65; }

  /* BRANDING LASTS */
  .branding-strip { background: var(--accent); padding: 1.5rem 4rem; }
  .branding-strip p { font-family: 'Bebas Neue', cursive; font-size: clamp(1.2rem, 2.5vw, 2rem); letter-spacing: 0.1em; color: var(--dark); text-align: center; }

  /* INTRO */
  #intro { padding: 7rem 4rem; background: var(--dark-2); display: grid; grid-template-columns: 1.2fr 1fr; gap: 6rem; align-items: start; }
  .intro-text p { color: var(--off-white); font-size: 1.05rem; line-height: 1.85; margin-bottom: 1.4rem; }
  .intro-text strong { color: var(--white); font-weight: 600; }
  .intro-pull { font-family: 'Bebas Neue', cursive; font-size: clamp(1.8rem, 3vw, 2.8rem); color: var(--accent); line-height: 1.1; margin-bottom: 1.5rem; }
  .intro-image { aspect-ratio: 3/4; overflow: hidden; position: relative; }
  .intro-image img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(10%); }
  .intro-image::before { content: ''; position: absolute; inset: 0; border: 0.5px solid var(--border); z-index: 1; pointer-events: none; }

  /* EXCLUSIVE CATEGORY — KEY DIFFERENTIATOR */
  #exclusive { padding: 6rem 4rem; background: var(--dark); }
  .exclusive-inner { max-width: 800px; margin: 0 auto; text-align: center; }
  .exclusive-inner .section-tag { justify-content: center; }
  .exclusive-big { font-family: 'Bebas Neue', cursive; font-size: clamp(3rem, 7vw, 6.5rem); line-height: 0.95; letter-spacing: 0.04em; margin: 1.5rem 0; }
  .exclusive-big span { color: var(--accent); }
  .exclusive-inner p { color: var(--off-white); font-size: 1.1rem; line-height: 1.8; max-width: 620px; margin: 0 auto; }
  .exclusive-caveat { font-family: 'Barlow Condensed', sans-serif; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--off-white); opacity: 0.5; margin-top: 1rem; }

  /* REACH NUMBERS */
  #reach { padding: 7rem 4rem; background: var(--dark-3); }
  .reach-header { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: end; margin-bottom: 4rem; }
  .reach-header p { color: var(--off-white); font-size: 1.05rem; line-height: 1.8; }
  .reach-header strong { color: var(--white); font-weight: 600; }
  .reach-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border-dim); }
  .reach-item { background: var(--dark-4); padding: 2.5rem 2rem; text-align: center; }
  .ri-num { font-family: 'Bebas Neue', cursive; font-size: 2.5rem; color: var(--accent); letter-spacing: 0.04em; line-height: 1; }
  .ri-sub { font-family: 'Barlow Condensed', sans-serif; font-size: 0.58rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); opacity: 0.65; margin-top: 0.15rem; }
  .ri-label { font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--off-white); margin-top: 0.4rem; }
  .reach-images { display: grid; grid-template-columns: repeat(5,1fr); gap: 2px; margin-top: 2px; }
  .reach-images img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; filter: grayscale(15%); transition: filter 0.3s; }
  .reach-images img:hover { filter: grayscale(0%); }

  /* SOCIAL MEDIA BREAKDOWN */
  #social { padding: 7rem 4rem; background: var(--dark-2); }
  .social-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; margin-top: 3rem; }
  .social-platform { background: var(--dark-3); border: 0.5px solid var(--border-dim); padding: 2.5rem; }
  .sp-name { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
  .sp-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border-dim); margin-bottom: 1.5rem; }
  .sp-stat { background: var(--dark-4); padding: 1.2rem; text-align: center; }
  .sp-stat-num { font-family: 'Bebas Neue', cursive; font-size: 1.8rem; color: var(--accent); line-height: 1; }
  .sp-stat-label { font-family: 'Barlow Condensed', sans-serif; font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--off-white); margin-top: 0.2rem; }
  .sp-features { list-style: none; }
  .sp-features li { font-size: 0.88rem; color: var(--off-white); padding: 0.45rem 0; border-bottom: 0.5px solid var(--border-dim); display: flex; gap: 0.8rem; align-items: flex-start; }
  .sp-features li::before { content: '→'; color: var(--accent); flex-shrink: 0; font-size: 0.8rem; margin-top: 0.05rem; }
  .whatsapp-platform { grid-column: 1 / -1; }

  /* INFLUENCER COMPETITION */
  #influencers { padding: 7rem 4rem; background: var(--dark); }
  .inf-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .inf-text p { color: var(--off-white); font-size: 1.05rem; line-height: 1.85; margin-bottom: 1.2rem; }
  .inf-text strong { color: var(--white); font-weight: 600; }
  .inf-mechanic { background: var(--dark-3); border: 0.5px solid var(--border); padding: 2.5rem; margin-top: 1.5rem; }
  .inf-mechanic h4 { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; }
  .inf-steps { list-style: none; counter-reset: inf-counter; }
  .inf-steps li { counter-increment: inf-counter; display: flex; gap: 1rem; font-size: 0.9rem; color: var(--off-white); padding: 0.6rem 0; border-bottom: 0.5px solid var(--border-dim); line-height: 1.5; }
  .inf-steps li::before { content: counter(inf-counter); font-family: 'Bebas Neue', cursive; color: var(--accent); font-size: 1rem; min-width: 1.2rem; }
  .inf-image { aspect-ratio: 3/4; overflow: hidden; }
  .inf-image img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(10%); }

  /* AUDIENCE */
  #audience { padding: 7rem 4rem; background: var(--dark-3); }
  .audience-layout { display: grid; grid-template-columns: 1fr 1.3fr; gap: 6rem; align-items: start; }
  .audience-text p { color: var(--off-white); font-size: 1.05rem; line-height: 1.85; margin-bottom: 1.2rem; }
  .audience-text strong { color: var(--white); font-weight: 600; }
  .audience-types { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border-dim); margin-top: 1rem; }
  .at { background: var(--dark-4); padding: 1.8rem 1.5rem; }
  .at-title { font-family: 'Bebas Neue', cursive; font-size: 1.6rem; color: var(--white); letter-spacing: 0.04em; line-height: 1; margin-bottom: 0.4rem; }
  .at-desc { font-size: 0.82rem; color: var(--off-white); line-height: 1.5; }
  .audience-image { aspect-ratio: 3/4; overflow: hidden; }
  .audience-image img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(10%); }
  .dwell-callout { background: rgba(137,207,240,0.08); border: 0.5px solid var(--border); padding: 1.5rem; margin-top: 1.5rem; }
  .dwell-callout p { font-size: 0.95rem; color: var(--off-white); line-height: 1.6; }
  .dwell-callout strong { color: var(--accent); font-weight: 600; font-size: 1.05rem; }

  /* SPONSOR BENEFITS */
  #sponsor-benefits { padding: 7rem 4rem; background: var(--dark-2); }
  .sb-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--border-dim); margin-top: 3rem; }
  .sb-card { background: var(--dark-3); padding: 2.5rem 2rem; transition: background 0.3s; }
  .sb-card:hover { background: var(--dark-4); }
  .sb-num { font-family: 'Bebas Neue', cursive; font-size: 2.5rem; color: var(--accent); opacity: 0.4; line-height: 1; margin-bottom: 1rem; }
  .sb-name { font-family: 'Barlow Condensed', sans-serif; font-size: 0.88rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--white); margin-bottom: 0.8rem; }
  .sb-desc { font-size: 0.9rem; color: var(--off-white); line-height: 1.65; }

  /* WHAT WE NEED FROM YOU */
  #requirements { padding: 7rem 4rem; background: var(--dark); }
  .req-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; margin-top: 3rem; }
  .req-item { border-top: 0.5px solid var(--border); padding-top: 2rem; }
  .req-name { font-family: 'Barlow Condensed', sans-serif; font-size: 0.85rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; }
  .req-desc { font-size: 0.92rem; color: var(--off-white); line-height: 1.7; }

  /* HOW IT WORKS */
  #how { padding: 7rem 4rem; background: var(--dark-3); }
  .steps-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border-dim); margin-top: 3rem; }
  .step { background: var(--dark-4); padding: 2.5rem 2rem; position: relative; }
  .step-num { font-family: 'Bebas Neue', cursive; font-size: 5rem; color: var(--accent); opacity: 0.1; line-height: 1; position: absolute; top: 1rem; right: 1.5rem; }
  .step-title { font-family: 'Barlow Condensed', sans-serif; font-size: 0.88rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--white); margin-bottom: 0.7rem; position: relative; z-index: 1; }
  .step-desc { font-size: 0.88rem; color: var(--off-white); line-height: 1.6; position: relative; z-index: 1; }

  /* CTA */
  #sponsor-cta { padding: 8rem 4rem; background: var(--dark-2); position: relative; overflow: hidden; }
  #sponsor-cta::before { content: 'SPONSOR'; position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%); font-family: 'Bebas Neue', cursive; font-size: 14rem; color: rgba(137,207,240,0.03); pointer-events: none; white-space: nowrap; }
  .cta-layout { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: start; }
  .cta-text h2 { font-family: 'Bebas Neue', cursive; font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 0.95; letter-spacing: 0.04em; margin-bottom: 1.2rem; }
  .cta-text p { color: var(--off-white); font-size: 1.05rem; line-height: 1.75; margin-bottom: 1.2rem; }
  .cta-text strong { color: var(--white); font-weight: 600; }
  .cta-form-box { background: var(--dark-3); padding: 3rem; border: 0.5px solid var(--border); }
  .cfb-title { font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.5rem; }
  .send-list { list-style: none; margin-bottom: 2rem; }
  .send-list li { display: flex; gap: 1rem; padding: 0.75rem 0; border-bottom: 0.5px solid var(--border-dim); font-size: 0.9rem; color: var(--off-white); line-height: 1.5; }
  .send-list li::before { content: '→'; color: var(--accent); flex-shrink: 0; font-size: 0.82rem; margin-top: 0.1rem; }
  .send-list li strong { color: var(--white); font-weight: 600; }
  .contact-row { margin-top: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .cr-item { font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--off-white); }
  .cr-item a { color: var(--accent); text-decoration: none; }

  footer { background: var(--dark); border-top: 0.5px solid var(--border-dim); padding: 2.5rem 4rem; display: flex; justify-content: space-between; align-items: center; }
  .footer-logo { font-family: 'Bebas Neue', cursive; font-size: 1.4rem; letter-spacing: 0.12em; color: var(--accent); text-decoration: none; }
  .footer-copy { font-size: 0.78rem; color: var(--off-white); }
  .footer-links { display: flex; gap: 2rem; list-style: none; }
  .footer-links a { font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--off-white); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: var(--accent); }

  @media (max-width: 900px) {
    nav { padding: 0 1.5rem; } .nav-links { display: none; }
    #intro, #influencers, .audience-layout, .cta-layout { grid-template-columns: 1fr; gap: 3rem; }
    .reach-grid { grid-template-columns: 1fr 1fr; }
    .social-layout { grid-template-columns: 1fr; }
    .reach-images { grid-template-columns: 1fr 1fr; }
    .sb-grid, .steps-grid { grid-template-columns: 1fr; }
    .audience-types, .req-layout { grid-template-columns: 1fr; }
    .branding-strip, #intro, #exclusive, #reach, #social, #influencers, #audience, #sponsor-benefits, #requirements, #how, #sponsor-cta { padding-left: 1.5rem; padding-right: 1.5rem; }
    .page-hero-content { padding-left: 1.5rem; }
    footer { flex-direction: column; gap: 1.5rem; text-align: center; }
    #sponsor-cta::before { font-size: 5rem; }
  }
</style>
</head>
