<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root { --accent: #89cff0; --white: #f0ede8; --off-white: #b0a99a; --dark: #0a0907; --dark-2: #111009; --dark-3: #1a1814; --dark-4: #242018; --border: rgba(137,207,240,0.2); --border-dim: rgba(255,255,255,0.07); }
