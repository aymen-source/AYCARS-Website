  .nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .nav-links a { font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--off-white); text-decoration: none; transition: color 0.2s; }
  .nav-links a:hover { color: var(--accent); }
  .nav-cta { font-family: 'Barlow Condensed', sans-serif; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dark); background: var(--accent); padding: 0.5rem 1.4rem; text-decoration: none; transition: opacity 0.2s; font-weight: 600; }
  .nav-cta:hover { opacity: 0.85; }
  .btn-primary { font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; background: var(--accent); color: var(--dark); padding: 0.9rem 2.2rem; text-decoration: none; display: inline-block; transition: opacity 0.2s; font-weight: 600; }
  .btn-primary:hover { opacity: 0.85; }
  .btn-ghost { font-family: 'Barlow Condensed', sans-serif; font-size: 0.78rem; letter-spacing: 0.2em; text-transform: uppercase; border: 0.5px solid rgba(137,207,240,0.5); color: var(--accent); padding: 0.9rem 2.2rem; text-decoration: none; display: inline-block; transition: background 0.2s; }
  .btn-ghost:hover { background: rgba(137,207,240,0.1); }
  .section-tag { font-family: 'Barlow Condensed', sans-serif; font-size: 0.68rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; display: flex; align-items: center; gap: 1rem; }
  .section-tag::before { content: ''; width: 30px; height: 0.5px; background: var(--accent); display: block; }
  .section-title { font-family: 'Bebas Neue', cursive; font-size: clamp(2.8rem, 5vw, 4.5rem); letter-spacing: 0.04em; line-height: 1; margin-bottom: 1.5rem; }
  .accent-divider { width: 40px; height: 0.5px; background: var(--accent); margin: 1.5rem 0; }

  /* HERO */
  .hero { height: 100vh; min-height: 700px; position: relative; display: flex; align-items: flex-end; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(10,9,7,0.25) 0%, rgba(10,9,7,0.05) 35%, rgba(10,9,7,0.88) 100%), url('https://images.squarespace-cdn.com/content/v1/66c2f5aa67e20d6721774f6f/1724052906795-09QAA39AOBP6Y1D8N0EY/Screenshot+2024-06-12+at+3.26.36+pm.png') center center / cover no-repeat; }
  .hero-locations { position: absolute; top: 90px; right: 3rem; z-index: 2; display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-end; }
  .hero-loc-pill { font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); background: rgba(10,9,7,0.65); border: 0.5px solid var(--border); padding: 0.3rem 0.9rem; backdrop-filter: blur(8px); }
  .hero-content { position: relative; z-index: 2; padding: 0 4rem 6rem; max-width: 850px; }
  .hero-eyebrow { font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--accent); margin-bottom: 1.2rem; display: flex; align-items: center; gap: 1rem; }
  .hero-eyebrow::before { content: ''; display: block; width: 40px; height: 0.5px; background: var(--accent); }
  .hero-title { font-family: 'Bebas Neue', cursive; font-size: clamp(4rem, 10vw, 8.5rem); line-height: 0.9; letter-spacing: 0.03em; color: var(--white); margin-bottom: 1.8rem; }
  .hero-title span { color: var(--accent); }
  .hero-sub { font-size: 1.05rem; font-weight: 300; color: var(--off-white); line-height: 1.7; max-width: 520px; margin-bottom: 2.5rem; }
  .hero-actions { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  .hero-scroll { position: absolute; bottom: 2.5rem; right: 4rem; z-index: 2; font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--off-white); writing-mode: vertical-rl; }

  /* PHILOSOPHY */
  .philosophy { background: var(--accent); padding: 1.4rem 4rem; text-align: center; }
  .philosophy p { font-family: 'Bebas Neue', cursive; font-size: clamp(1rem, 2vw, 1.6rem); letter-spacing: 0.1em; color: var(--dark); }

  /* STATS */
  .stats-bar { background: var(--dark-3); border-top: 0.5px solid var(--border); border-bottom: 0.5px solid var(--border-dim); padding: 2.2rem 4rem; display: grid; grid-template-columns: repeat(5,1fr); }
  .stat-item { text-align: center; padding: 0.5rem 1rem; border-right: 0.5px solid var(--border-dim); }
  .stat-item:last-child { border-right: none; }
  .stat-num { font-family: 'Bebas Neue', cursive; font-size: 2.1rem; color: var(--accent); letter-spacing: 0.05em; line-height: 1; }
  .stat-label { font-family: 'Barlow Condensed', sans-serif; font-size: 0.6rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--off-white); margin-top: 0.3rem; }
  .stat-sub { font-family: 'Barlow Condensed', sans-serif; font-size: 0.53rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--accent); opacity: 0.6; margin-top: 0.1rem; }

  /* ABOUT */
  #about { background: var(--dark-2); display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; padding: 7rem 4rem; }
  .about-image { position: relative; aspect-ratio: 3/4; overflow: hidden; }
  .about-image img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(12%); }
  .about-image::before { content: ''; position: absolute; inset: 0; border: 0.5px solid var(--border); z-index: 1; pointer-events: none; }
  .about-image::after { content: ''; position: absolute; top: 1.5rem; left: -1.5rem; width: 0.5px; height: 60%; background: var(--accent); }
  .about-body p { color: var(--off-white); font-size: 1.05rem; line-height: 1.85; margin-bottom: 1.4rem; }
  .about-body strong { color: var(--white); font-weight: 600; }
  .loc-tags { display: flex; gap: 0.8rem; margin: 1.5rem 0; flex-wrap: wrap; }
  .loc-tag { font-family: 'Barlow Condensed', sans-serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; border: 0.5px solid var(--border); color: var(--accent); padding: 0.35rem 0.9rem; }

  /* EVENT FORMAT */
  #event-format { padding: 7rem 4rem; background: var(--dark); }
  .event-steps { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; background: var(--border-dim); margin-top: 3rem; }
  .event-step { background: var(--dark-3); padding: 3rem 2.5rem; transition: background 0.3s; }
  .event-step:hover { background: var(--dark-4); }
  .step-num-bg { font-family: 'Bebas Neue', cursive; font-size: 5rem; color: var(--accent); opacity: 0.08; line-height: 1; margin-bottom: 0.3rem; }
  .step-tag { font-family: 'Barlow Condensed', sans-serif; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.5rem; }
  .step-name { font-family: 'Bebas Neue', cursive; font-size: 2.2rem; color: var(--white); letter-spacing: 0.04em; margin-bottom: 1rem; line-height: 1; }
  .step-desc { font-size: 0.92rem; color: var(--off-white); line-height: 1.72; }
  .step-detail { font-size: 0.78rem; color: var(--accent); font-family: 'Barlow Condensed', sans-serif; letter-spacing: 0.12em; margin-top: 1.2rem; opacity: 0.8; }

  /* EVENT TYPES */
  #event-types { padding: 6rem 4rem; background: var(--dark-2); }
  .events-intro { max-width: 680px; margin-bottom: 3rem; }
  .events-intro p { color: var(--off-white); font-size: 1.05rem; line-height: 1.8; margin-top: 1rem; }
  .event-types-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 1px; background: var(--border-dim); }
  .event-type-item { background: var(--dark-3); padding: 2rem 1.5rem; text-align: center; transition: background 0.3s; }
  .event-type-item:hover { background: var(--dark-4); }
  .eti-icon { font-family: 'Bebas Neue', cursive; font-size: 2.5rem; color: var(--accent); opacity: 0.5; line-height: 1; margin-bottom: 0.8rem; }
  .eti-name { font-family: 'Barlow Condensed', sans-serif; font-size: 0.82rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--white); }

  /* PAGE CARDS */
  #features { background: var(--dark); padding: 7rem 4rem; }
  .features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--border-dim); margin-top: 3rem; }
  .feature-card { background: var(--dark-3); padding: 2.5rem 2rem; transition: background 0.3s; }
  .feature-card:hover { background: var(--dark-4); }
  .fc-num { font-family: 'Bebas Neue', cursive; font-size: 3rem; color: var(--accent); line-height: 1; margin-bottom: 1rem; opacity: 0.55; }
  .fc-name { font-family: 'Barlow Condensed', sans-serif; font-size: 1rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--white); margin-bottom: 0.8rem; }
  .fc-desc { font-size: 0.9rem; color: var(--off-white); line-height: 1.65; }
  .fc-link { display: inline-block; margin-top: 1.2rem; font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--accent); text-decoration: none; border-bottom: 0.5px solid rgba(137,207,240,0.35); padding-bottom: 2px; transition: border-color 0.2s; }
  .fc-link:hover { border-color: var(--accent); }

  /* GALLERY */
  #gallery { background: var(--dark); padding: 7rem 4rem 0; }
  .gallery-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
  .gallery-grid { display: grid; grid-template-columns: repeat(12,1fr); grid-template-rows: 320px 280px; gap: 2px; }
  .gallery-item { overflow: hidden; }
  .gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(10%) contrast(1.05); transition: transform 0.5s ease, filter 0.4s; }
  .gallery-item:hover img { transform: scale(1.05); filter: grayscale(0%) contrast(1.05); }
  .gi-1{grid-column:1/6;} .gi-2{grid-column:6/10;} .gi-3{grid-column:10/13;}
  .gi-4{grid-column:1/4;} .gi-5{grid-column:4/8;} .gi-6{grid-column:8/13;}

  /* CONTACT */
  #contact { background: var(--dark-3); text-align: center; position: relative; overflow: hidden; padding: 8rem 4rem; }
  #contact::before { content: 'AYCARS'; position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%); font-family: 'Bebas Neue', cursive; font-size: 16rem; color: rgba(137,207,240,0.03); pointer-events: none; white-space: nowrap; }
  .contact-inner { position: relative; z-index: 2; max-width: 620px; margin: 0 auto; }
  .contact-inner .section-tag { justify-content: center; }
  .contact-inner .section-title { font-size: clamp(3rem, 6vw, 6rem); }
  .contact-inner p { color: var(--off-white); font-size: 1.05rem; line-height: 1.75; margin-bottom: 2.5rem; }
  .contact-inner .accent-divider { margin: 1.5rem auto; }
  .contact-btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .contact-details { display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; }
  .cd-item { font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--off-white); }
  .cd-item a { color: var(--accent); text-decoration: none; }

  footer { background: var(--dark); border-top: 0.5px solid var(--border-dim); padding: 2.5rem 4rem; display: flex; justify-content: space-between; align-items: center; }
  .footer-logo { font-family: 'Bebas Neue', cursive; font-size: 1.4rem; letter-spacing: 0.12em; color: var(--accent); text-decoration: none; }
  .footer-copy { font-size: 0.78rem; color: var(--off-white); }
  .footer-links { display: flex; gap: 2rem; list-style: none; }
  .footer-links a { font-family: 'Barlow Condensed', sans-serif; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--off-white); text-decoration: none; transition: color 0.2s; }
  .footer-links a:hover { color: var(--accent); }

  @media (max-width: 900px) {
    nav { padding: 0 1.5rem; } .nav-links { display: none; }
    .hero-content { padding: 0 1.5rem 5rem; } .hero-scroll, .hero-locations { display: none; }
    .stats-bar { grid-template-columns: 1fr 1fr; padding: 1.8rem 1.5rem; }
    .stat-item:nth-child(2), .stat-item:nth-child(4) { border-right: none; }
    .stat-item:nth-child(5) { grid-column: 1 / -1; border-right: none; }
    .philosophy { padding: 1.2rem 1.5rem; }
    #about { grid-template-columns: 1fr; gap: 3rem; padding: 5rem 1.5rem; }
    #event-format, #event-types, #features, #gallery, #contact { padding-left: 1.5rem; padding-right: 1.5rem; }
    .event-steps, .features-grid { grid-template-columns: 1fr; }
    .event-types-grid { grid-template-columns: 1fr 1fr; }
    .gallery-grid { grid-template-columns: 1fr 1fr; grid-template-rows: unset; }
    .gi-1,.gi-2,.gi-3,.gi-4,.gi-5,.gi-6 { grid-column: auto; aspect-ratio: 4/3; }
    footer { flex-direction: column; gap: 1.5rem; text-align: center; }
    #contact::before { font-size: 5rem; }
  }
</style>
</head>
