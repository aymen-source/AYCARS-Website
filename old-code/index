  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 0 3rem; height: 70px; background: rgba(10,9,7,0.92); backdrop-filter: blur(12px); border-bottom: 0.5px solid var(--border-dim); transition: background 0.3s; }
